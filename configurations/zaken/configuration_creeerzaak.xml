<Module
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:noNamespaceSchemaLocation="../FrankConfig.xsd"
	>
	<Adapter name="Creeer Zaak">
		<Receiver name="local-zaak">
			<WebServiceListener name="local-zaak-listener" soapAction="creerzaak" />
		</Receiver>
		<Pipeline>
			<SoapInputValidator name="validateZaak" 
					schemaLocation="http://example.com/zaak creeerzaak\xsd\creeerzaak.xsd" soapBody="CreeerZaakRequest" outputSoapBody="CreeerZaakResponse">
				<Forward name="exception" path="error" />
				<Forward name="failure" path="error" />
				<Forward name="outputFailure" path="READY" />
<!--			<Forward name="parserError" path="okay" />
				
				<Forward name="warnings" path="okay" />
				<Forward name="outputParserError" path="okay" />
				<Forward name="outputFailure" path="okay" />
				<Forward name="outputWarnings" path="okay" />
-->	
			</SoapInputValidator>
						
			<Exits>
				<Exit name="READY" state="SUCCESS" />
			</Exits>
			
			<EchoPipe name="okay">
				<Forward name="success" path="READY"/>
			</EchoPipe>

			
			<EchoPipe name="error">
				<Forward name="success" path="READY"/>
			</EchoPipe>

		</Pipeline>
	</Adapter>
	
</Module>